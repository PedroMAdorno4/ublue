#!/bin/bash
# Rotate each connected monitor's wallpaper to a random image matching its
# current aspect ratio, then regenerate the matugen theme from the
# color-source monitor's pick.
#
# DP-2 is the sole color source for theming purposes, matching the previous
# mpvpaper-based setup -- this is an intentional simplification, not an
# oversight.

set -uo pipefail

WALLPAPER_DIR="$HOME/Pictures/wallpapers"
THEME_OUTPUT="DP-2"

# Give awww-daemon a moment to create its socket if it just started.
for _ in $(seq 1 10); do
    awww query >/dev/null 2>&1 && break
    sleep 1
done

mapfile -t outputs < <(niri msg -j outputs |
    jq -r 'to_entries[] | select(.value.logical != null) |
        "\(.key) \(.value.modes[.value.current_mode].width) \(.value.modes[.value.current_mode].height)"')

for entry in "${outputs[@]}"; do
    read -r name width height <<< "$entry"
    a=$width; b=$height
    while [[ "$b" -ne 0 ]]; do
        a=$((a % b)); read -r a b <<< "$b $a"
    done
    gcd=$a
    dir="$WALLPAPER_DIR/$((width / gcd))x$((height / gcd))"
    [[ -d "$dir" ]] || continue

    image=$(find "$dir" -maxdepth 1 -type f | shuf -n1)
    [[ -n "$image" ]] || continue

    awww img -o "$name" --transition-type fade --transition-duration 2 "$image"

    if [[ "$name" == "$THEME_OUTPUT" ]]; then
        matugen image "$image" >/dev/null 2>&1
    fi
done
