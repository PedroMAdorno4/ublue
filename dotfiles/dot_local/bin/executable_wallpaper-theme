#!/bin/bash
# Poll mpvpaper's IPC socket for the currently playing wallpaper video and,
# whenever it changes, extract a mid-point frame and feed it to matugen to
# regenerate the system Material-You palette. Meant to be run periodically
# by wallpaper-theme.timer.
#
# Only DP-2's mpvpaper instance exposes an IPC socket (input-ipc-server); the
# DP-3 instance does not. That's an intentional simplification: DP-2 is used
# as the sole color source for theming purposes.
#
# The socket lives under $XDG_RUNTIME_DIR with a name unique to this
# mpvpaper instance (see mpvpaper-dp2.service), not a shared /tmp path, so it
# can never be confused with a regular mpv window someone opens to watch a
# video. As a second layer of defense, the reported path is also required to
# live under the wallpaper directory before it's used as a color source.

set -uo pipefail

WALLPAPER_DIR="$(realpath -q "$HOME/videos/wallpapers/landscape")"
MPV_SOCKET="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/mpvpaper-dp2.sock"
CACHE_DIR="$HOME/.cache/wallpaper-theme"
CACHE_FILE="$CACHE_DIR/current"
FRAME_FILE="$CACHE_DIR/frame.png"

mkdir -p "$CACHE_DIR"

# Query the currently playing file path from mpv over its JSON IPC socket.
# If mpv isn't up yet or the socket doesn't exist, fail quietly.
response=$(echo '{ "command": ["get_property", "path"] }' | socat - "$MPV_SOCKET" 2>/dev/null)
if [[ -z "$response" ]]; then
    exit 1
fi

path=$(echo "$response" | jq -r 'select(.data != null) | .data' 2>/dev/null | head -n1)
if [[ -z "$path" || ! -f "$path" ]]; then
    exit 1
fi

# Refuse to use anything outside the wallpaper directory as a color source,
# in case this socket path is ever reused by something other than mpvpaper.
case "$(realpath -q "$path" 2>/dev/null)" in
    "$WALLPAPER_DIR"/*) ;;
    *) exit 1 ;;
esac

# Nothing to do if the video hasn't changed since the last run.
last_path=""
if [[ -f "$CACHE_FILE" ]]; then
    last_path=$(cat "$CACHE_FILE")
fi

if [[ "$path" == "$last_path" ]]; then
    exit 0
fi

duration=$(ffprobe -v error -show_entries format=duration -of csv=p=0 "$path" 2>/dev/null)
if [[ -z "$duration" ]]; then
    exit 1
fi

midpoint=$(awk -v d="$duration" 'BEGIN { printf "%.2f", d / 2 }')

if ! ffmpeg -y -ss "$midpoint" -i "$path" -frames:v 1 "$FRAME_FILE" >/dev/null 2>&1; then
    exit 1
fi

matugen image "$FRAME_FILE" >/dev/null 2>&1

echo "$path" > "$CACHE_FILE"
