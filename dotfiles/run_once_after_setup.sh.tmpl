#!/bin/bash
# Runs once after chezmoi apply on a fresh system

set -euo pipefail

# Make user scripts executable
chmod +x "$HOME/.local/bin/switch-audio"
chmod +x "$HOME/.local/bin/projectfinder"
chmod +x "$HOME/.local/bin/tmux-sessionizer"

# tmux plugin manager
if [[ ! -d "$HOME/.tmux/plugins/tpm" ]]; then
    git clone --depth=1 https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
fi

# yazi whoosh bookmark plugin
if [[ ! -d "$HOME/.config/yazi/plugins/whoosh.yazi" ]]; then
    git clone --depth=1 https://github.com/sxyazi/whoosh.yazi ~/.config/yazi/plugins/whoosh.yazi
fi

# Ensure zsh history dir exists
mkdir -p "${XDG_DATA_HOME:-$HOME/.local/share}/zsh"

# Ensure npm-global dir exists
mkdir -p "$HOME/.npm-global/bin"

# Enable user systemd services for wallpaper and polkit
systemctl --user enable --now mpvpaper-dp3.service mpvpaper-dp2.service || true
systemctl --user enable --now polkit-gnome-authentication-agent-1.service || true

# Set default shell to zsh if not already
if [[ "$SHELL" != "$(which zsh)" ]]; then
    chsh -s "$(which zsh)"
fi
